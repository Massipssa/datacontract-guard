DATA_CONTRACT_ENV=local
DATA_CONTRACT_ALLOWED_ROOTS=.
DATA_CONTRACT_MAX_FILE_BYTES=5242880
DATA_CONTRACT_MAX_COLUMNS=500
DATA_CONTRACT_MAX_CONTRACT_COLUMNS=500
DATA_CONTRACT_MAX_DATA_ROWS=1000
DATA_CONTRACT_API_KEY=change-me
DATA_CONTRACT_LOG_LEVEL=INFO
DATA_CONTRACT_DOCS_PATH=./docs
DATA_CONTRACT_ENABLE_VECTOR_STORE=false
DATA_CONTRACT_VECTOR_STORE_PATH=./.chroma_store

# MCP (Managed Connector Proxy) configuration
# If you use an MCP service, set its base URL and a bearer token
DATA_CONTRACT_MCP_URL=
DATA_CONTRACT_MCP_TOKEN=
